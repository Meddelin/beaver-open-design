{
  "name": "@beaver-open-design/spec-extractor",
  "version": "0.2.0",
  "private": true,
  "description": "CLI: introspect the prebuilt Beaver UI runtime bundle, walk published .d.ts via TS Compiler API, and emit a lean manifest + per-component specs + token groups + doc corpus consumed by the daemon's beaver-tools layer.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "bin": {
    "beaver-sync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.17.10",
    "tsx": "4.21.0"
  }
}

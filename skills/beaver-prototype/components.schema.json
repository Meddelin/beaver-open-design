{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Beaver components manifest",
  "description": "Auto-generated by `pnpm beaver:sync`. Edit the source repo, not this file.",
  "type": "object",
  "required": ["components", "tokens"],
  "properties": {
    "generatedAt": { "type": ["string", "null"], "format": "date-time" },
    "generatedBy": { "type": "string" },
    "beaverVersion": { "type": ["string", "null"] },
    "innerDsVersion": { "type": ["string", "null"] },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    },
    "tokens": {
      "type": "object",
      "description": "Flat catalog of every token, keyed by group (colors, spacing, typography, animation, …).",
      "additionalProperties": { "$ref": "#/$defs/tokenGroup" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["name", "package", "tier", "importStatement", "props"],
      "properties": {
        "name": { "type": "string" },
        "package": { "type": "string", "description": "e.g. @beaver-ui/button" },
        "tier": { "enum": ["preferred", "primitive"] },
        "importStatement": { "type": "string", "description": "Verbatim line the LLM should emit." },
        "summary": { "type": "string" },
        "props": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "required"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "default": {},
              "description": { "type": "string" },
              "enumValues": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "examples": {
          "type": "array",
          "items": { "type": "string", "description": "TSX snippet" }
        }
      }
    },
    "tokenGroup": {
      "type": "object",
      "description": "A category of design tokens (e.g. colors, spacing).",
      "required": ["importPath", "values"],
      "properties": {
        "importPath": { "type": "string", "description": "e.g. @<inner-ds>/design-tokens/colors" },
        "values": {
          "type": "object",
          "description": "Path → value (string for css, number for px, object for nested).",
          "additionalProperties": true
        }
      }
    }
  }
}
